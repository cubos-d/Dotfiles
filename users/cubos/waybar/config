{
    "layer": "top", // Waybar at top layer
    "position": "left", // Waybar at the bottom of your screen
    //"height": 1080, // Waybar height
	"margin-left": 5,
	"margin-right": 5,
	"margin-top": 5,
	"margin-bottom": 5,
    // "width": 1366, // Waybar width
    // Choose the order of the modules
    //"modules-center": ["hyprland/window"],
    "modules-left": ["custom/start", "hyprland/workspaces"],
    "modules-right": ["pulseaudio", "network", "cpu", "memory", "tray", "clock", "custom/void"],
    "hyprland/workspaces": {
		"persistent-workspaces": {
			"*":10
		},
        "disable-scroll": true,
        "format": "{icon}",
        "format-icons": {	
            "1": "ΌηΧ",
            "2": "≤░ΝΑ",
            "3": "ΎΝΨ",
            "4": "ΎΤ╕",
            "5": "≤▒κη",
            "6": "ΎΞξ",
            "7": "≤░Ε╗",
	    "8": "≤░Λ┤",
	    "9": "≤░βψ",
	    "10": "ΌεΤ", // ≤░φΕ  ≤░βψ  Όζν  ΌΙχ  ΌΙξ  ≤░Λ┤  ≤▒Ξλ  ΎΡΑ  ≤░Ε╗  ΎΤ╕  ΎΝΛ  ≤▒Αν ΎΛΒ  ΎΕκ  ΎΝμ  ≤▒κη  ≤░γζ  ΌεΤ ΌιΠ ≤░ΝΑ ΎΝΨ
            "urgent": "ΎΒς",
            "focused": "ΎΗΤ",
            "default": "ΎΕΣ"
        }
    },
    "hyprland/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
		"format": "{:%H:%M}",
        "format-alt": "{:%Y \nM: %m\nD: %d}"
    },
    "cpu": {
        "format": "\nΎΜδ\n{usage}%"
    },
    "memory": {
        "format": "\nΎΔΚ\n{}%\n"
    },
    "battery": {
        "bat": "BAT0",
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "network": {
        // "interface": "wlp2s0", // (Optional) To force the use of this interface
        "format-wifi": "ΎΘτ \n{signalStrength}%",
        "format-ethernet": "ΎΔΒ",
        "format-disconnected": "έγι"
    },
    "pulseaudio": {
        //"scroll-step": 1,
        "format": "\n{icon}\n{volume}%\n",
        "format-bluetooth": "\nΎΛΦ{icon}\n{volume}%\n",
        "format-muted": "ΎΑο",
        "format-icons": {
            "headphones": "ΎΑξ",
            "handsfree": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },
    "custom/spotify": {
        "format": "ΎΗ╝ {}",
        "max-length": 40,
        "interval": 30, // Remove this if your script is endless and write in loop
        "exec": "$HOME/.config/waybar/mediaplayer.sh 2> /dev/null", // Script in resources folder
        "exec-if": "pgrep spotify"
    },
	"custom/void": {
		"format": "\n"
	},
	"custom/start": {
		"format": "\nΎΝΥ\n",
		"icon-size": 30,
		"on-click": "wlogout --protocol layer-shell" 
	}
}
